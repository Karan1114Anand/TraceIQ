# Environment Configuration — Autonomous Research Analyst
# Copy this file to .env and edit as needed.
# All settings have sensible defaults — no changes required to run.

# ============================================================================
# OLLAMA (Local LLM — text generation)
# ============================================================================
OLLAMA_MODEL=mistral
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TEMPERATURE=0.25
OLLAMA_TOP_P=0.9
OLLAMA_NUM_CTX=4096
OLLAMA_TIMEOUT=120

# ============================================================================
# EMBEDDINGS (Local sentence-transformers — no API key needed)
# ============================================================================
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# If model download is blocked (firewall/offline), set the path to a
# pre-downloaded model folder:
# HF_LOCAL_MODEL_PATH=C:\path\to\all-MiniLM-L6-v2

# ============================================================================
# VECTOR STORE
# ============================================================================
CHROMA_COLLECTION_NAME=research_docs
# CHROMA_PERSIST_DIR is auto-set to data/chroma_db/

# ============================================================================
# RETRIEVAL
# ============================================================================
RETRIEVAL_TOP_K=10      # Chunks fetched per query (before reranking)
RERANK_TOP_K=5          # Chunks kept after reranking
RRF_K=60                # Reciprocal Rank Fusion constant

# ============================================================================
# PIPELINE / AGENTS
# ============================================================================
MAX_RESEARCH_ITERATIONS=3     # Max retrieval loop cycles before forcing finalize
MIN_CONFIDENCE_SCORE=0.7      # Below this → gap analysis triggers another loop
CONTEXT_TOKEN_BUDGET=3000     # Max tokens passed to the synthesizer

# ============================================================================
# OUTPUT
# ============================================================================
OUTPUT_DIR=outputs
LOG_LEVEL=INFO
