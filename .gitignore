# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ───────────────────────────────────
.venv/
venv/
env/
ENV/
.env.local

# ── Environment / secrets ──────────────────────────────────
.env
!.env.example

# ── Jupyter ────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── OS ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Runtime data (empty dirs tracked via .gitkeep) ─────────
data/uploads/*
!data/uploads/.gitkeep
data/chroma_db/*
!data/chroma_db/.gitkeep
outputs/*
!outputs/.gitkeep
logs/*
!logs/.gitkeep

# ── BM25 index (regenerated on first run) ──────────────────
data/bm25_index.pkl

# ── Test artifacts ─────────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
